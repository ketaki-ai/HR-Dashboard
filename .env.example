# .env.example — copy to .env.local and fill in values

# ─── DATABASE (Supabase / Neon / Railway PostgreSQL) ───────────────────────────
# Get from your Postgres provider dashboard
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE"

# ─── VERCEL BLOB (for CV file uploads) ─────────────────────────────────────────
# Get from Vercel Dashboard → Storage → Blob → .env.local button
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxxxxxx"

# ─── CRON / WEBHOOK SECURITY ──────────────────────────────────────────────────
# Any random secret string — used to protect /api/cron route
CRON_SECRET="your-random-secret-32chars-min"

# ─── OPTIONAL: OpenAI for smarter CV parsing ──────────────────────────────────
OPENAI_API_KEY="sk-..."

# ─── APP CONFIG ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app" 
