// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Candidate {
  id                  String         @id @default(cuid())
  srNo                Int?
  name                String
  email               String?
  phone               String?
  education           String?
  currentLocation     String?
  positionApplied     String
  department          String
  totalExperience     String?
  relevantExperience  String?
  source              String?
  sourceDetails       String?
  hrInterviewer       String?
  technicalRound      String?
  finalRound          String?
  finalStatus         FinalStatus    @default(PENDING)
  offeredCtc          Float?
  doj                 DateTime?
  offerAccepted       OfferStatus?
  joined              JoinStatus?
  reasonNotJoining    String?
  interviewDate       DateTime?
  monthYear           DateTime?
  cvFileUrl           String?
  cvFileName          String?
  parsedData          Json?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  @@index([finalStatus])
  @@index([department])
  @@index([interviewDate])
  @@index([source])
}

model UploadBatch {
  id          String   @id @default(cuid())
  fileName    String
  fileUrl     String?
  status      String   @default("processing")
  parsed      Int      @default(0)
  failed      Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AnalyticsSnapshot {
  id              String   @id @default(cuid())
  snapshotDate    DateTime @default(now())
  totalProfiles   Int
  totalSelected   Int
  totalJoined     Int
  totalRejected   Int
  totalShortlisted Int
  selectionRate   Float
  joinRate        Float
  avgCtc          Float?
  byDepartment    Json
  bySource        Json
  byMonth         Json
  createdAt       DateTime @default(now())
}

enum FinalStatus {
  SELECTED
  REJECTED
  SHORTLISTED
  PENDING
  IN_PROGRESS
}

enum OfferStatus {
  YES
  NO
  PENDING
}

enum JoinStatus {
  YES
  NO
  PENDING
}
